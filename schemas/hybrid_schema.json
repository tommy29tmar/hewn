{
  "type": "json_schema",
  "name": "sigil_hybrid",
  "strict": true,
  "schema": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "mode",
      "codebook",
      "goal",
      "constraints",
      "has_hypothesis",
      "hypothesis_left",
      "hypothesis_right",
      "plan",
      "verification",
      "risks",
      "questions",
      "answer",
      "audit"
    ],
    "properties": {
      "mode": {
        "type": "string",
        "enum": ["hybrid"]
      },
      "codebook": {
        "type": "array",
        "maxItems": 3,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["symbol", "value"],
          "properties": {
            "symbol": { "type": "string" },
            "value": { "type": "string" }
          }
        }
      },
      "goal": { "type": "string", "pattern": "^[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+(?:\\((?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+')(?:,(?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+'))*\\))?$" },
      "constraints": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string", "pattern": "^[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+(?:\\((?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+')(?:,(?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+'))*\\))?$" }
      },
      "has_hypothesis": { "type": "boolean" },
      "hypothesis_left": { "type": "string", "pattern": "^$|^[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+(?:\\((?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+')(?:,(?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+'))*\\))?$" },
      "hypothesis_right": { "type": "string", "pattern": "^$|^[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+(?:\\((?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+')(?:,(?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+'))*\\))?$" },
      "plan": {
        "type": "array",
        "minItems": 1,
        "maxItems": 5,
        "items": { "type": "string", "pattern": "^[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+(?:\\((?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+')(?:,(?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+'))*\\))?$" }
      },
      "verification": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string", "pattern": "^[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+(?:\\((?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+')(?:,(?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+'))*\\))?$" }
      },
      "risks": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string", "pattern": "^[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+(?:\\((?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+')(?:,(?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+'))*\\))?$" }
      },
      "questions": {
        "type": "array",
        "items": { "type": "string", "pattern": "^[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+(?:\\((?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+')(?:,(?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+'))*\\))?$" }
      },
      "answer": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string", "pattern": "^[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+(?:\\((?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+')(?:,(?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+'))*\\))?$" }
      },
      "audit": { "type": "string" }
    }
  }
}
