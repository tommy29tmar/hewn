{
  "type": "json_schema",
  "name": "review_hybrid",
  "strict": true,
  "schema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["mode", "finding", "exploit", "mitigation", "verification", "risks", "answer", "audit"],
    "properties": {
      "mode": { "type": "string", "enum": ["hybrid"] },
      "finding": { "type": "string", "pattern": "^[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+(?:\\((?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+')(?:,(?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+'))*\\))?$" },
      "exploit": { "type": "string", "pattern": "^[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+(?:\\((?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+')(?:,(?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+'))*\\))?$" },
      "mitigation": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string", "pattern": "^[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+(?:\\((?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+')(?:,(?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+'))*\\))?$" }
      },
      "verification": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string", "pattern": "^[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+(?:\\((?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+')(?:,(?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+'))*\\))?$" }
      },
      "risks": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string", "pattern": "^[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+(?:\\((?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+')(?:,(?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+'))*\\))?$" }
      },
      "answer": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string", "pattern": "^[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+(?:\\((?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+')(?:,(?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+'))*\\))?$" }
      },
      "audit": { "type": "string" }
    }
  }
}
