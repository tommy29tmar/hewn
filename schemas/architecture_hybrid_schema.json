{
  "type": "json_schema",
  "name": "architecture_hybrid",
  "strict": true,
  "schema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["mode", "decision", "constraints", "reasons", "plan", "risks", "answer", "audit"],
    "properties": {
      "mode": { "type": "string", "enum": ["hybrid"] },
      "decision": { "type": "string", "pattern": "^[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+$" },
      "constraints": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string", "pattern": "^[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+(?:\\((?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+')(?:,(?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+'))*\\))?$" }
      },
      "reasons": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string", "pattern": "^[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+(?:\\((?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+')(?:,(?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+'))*\\))?$" }
      },
      "plan": {
        "type": "array",
        "minItems": 1,
        "maxItems": 5,
        "items": { "type": "string", "pattern": "^[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+(?:\\((?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+')(?:,(?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+'))*\\))?$" }
      },
      "risks": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string", "pattern": "^[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+(?:\\((?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+')(?:,(?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+'))*\\))?$" }
      },
      "answer": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string", "pattern": "^[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+(?:\\((?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+')(?:,(?:[A-Za-z0-9_./:+\\-\\[\\]'\"<>]+|\"[^\"]+\"|'[^']+'))*\\))?$" }
      },
      "audit": { "type": "string" }
    }
  }
}
