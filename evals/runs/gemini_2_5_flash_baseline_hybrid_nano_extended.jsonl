{"task_id": "security-review-open-redirect", "variant": "baseline-terse", "model": "gemini-2.5-flash", "provider": "gemini", "prompt_path": "prompts/baseline_terse.txt", "draft_prompt_path": null, "structured_expected": false, "content": "Returning a `302` header with a `Location` field set to a user-controlled value creates an open redirect. If the redirect is to an authenticated endpoint, this could expose the user's session or other sensitive information to an attacker via a spoofed `Host` header. Drop the `Location` header to mitigate this risk. If the user is unauthenticated, return a `401` status code instead. If the user is unauthenticated and the `Location` header is spoofed, deny the request. Verify that dropping the header prevents the redirect.", "transport": "plain", "usage": {"stage_count": 1, "input_tokens": 90, "output_tokens": 117, "total_tokens": 207, "cached_tokens": null, "reasoning_tokens": null}, "stage_usages": [{"input_tokens": 90, "output_tokens": 117, "total_tokens": 207, "cached_tokens": null, "reasoning_tokens": null}], "elapsed_ms": 1599.44, "response_id": "GfTgaYmVF_CNxN8P_M_YwAU", "status": "STOP"}
