#!/usr/bin/env bash
# flint-mcp — Claude Code wrapper: flint + MCP server for schema-validated IR.
#
# Opt-in advanced lane. Combines:
#   - Flint thinking-mode system prompt (via --append-system-prompt)
#   - MCP server exposing submit_flint_ir (via --mcp-config)
#   - Per-turn drift-fix hook (via --settings file with UserPromptSubmit hook)
#
# Use this when downstream consumers need JSON-schema-validated IR (audit
# engine, lint pipeline, search indexing). On interactive long sessions
# the MCP tool round-trip adds token overhead vs the `flint` wrapper —
# prefer `flint` unless you need validated IR via `submit_flint_ir`.

set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

resolve_file() {
  local name="$1"; shift
  for candidate in "$@"; do
    if [ -n "$candidate" ] && [ -f "$candidate" ]; then
      echo "$candidate"
      return
    fi
  done
  echo "flint-mcp: $name not found" >&2
  for candidate in "$@"; do
    echo "  searched: $candidate" >&2
  done
  return 1
}

prompt_file="$(resolve_file "thinking-mode-MCP prompt" \
  "${FLINT_THINKING_MCP_PROMPT_FILE:-}" \
  "$HOME/.claude/flint_thinking_mcp_system_prompt.txt" \
  "$script_dir/../flint_thinking_mcp_system_prompt.txt")" || exit 1

mcp_config_file="$(resolve_file "MCP config" \
  "${FLINT_MCP_CONFIG_FILE:-}" \
  "$HOME/.claude/flint-mcp-config.json" \
  "$script_dir/../mcp-config.json")" || exit 1

settings_file="$(resolve_file "drift-fix settings" \
  "${FLINT_DRIFT_FIX_SETTINGS_FILE:-}" \
  "$HOME/.claude/flint-drift-fix-settings.json" \
  "$script_dir/../flint-drift-fix-settings.json")" || exit 1

prompt_body="$(cat "$prompt_file")"
exec claude \
  --append-system-prompt "$prompt_body" \
  --mcp-config "$mcp_config_file" \
  --settings "$settings_file" \
  "$@"
