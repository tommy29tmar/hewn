#!/usr/bin/env bash
# flint — Claude Code wrapper: thinking-mode prompt + per-turn drift-fix hook.
#
# Default Flint lane. Combines:
#   - Flint thinking-mode system prompt (via --append-system-prompt) —
#     Caveman-shape prose for user-facing output, IR for IR-shape tasks.
#   - Per-turn drift-fix hook (via --settings file with UserPromptSubmit
#     hook) that re-injects the task-shape classification on every turn,
#     preventing T2+ drift seen with system-prompt-only wrappers.
#
# IR emitted as free text (no MCP round-trip). For schema-validated IR
# (downstream pipeline use-case), see the `flint-mcp` wrapper.

set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

resolve_file() {
  local name="$1"; shift
  for candidate in "$@"; do
    if [ -n "$candidate" ] && [ -f "$candidate" ]; then
      echo "$candidate"
      return
    fi
  done
  echo "flint: $name not found" >&2
  for candidate in "$@"; do
    echo "  searched: $candidate" >&2
  done
  return 1
}

prompt_file="$(resolve_file "thinking-mode prompt" \
  "${FLINT_THINKING_PROMPT_FILE:-}" \
  "$HOME/.claude/flint_thinking_system_prompt.txt" \
  "$script_dir/../flint_thinking_system_prompt.txt")" || exit 1

settings_file="$(resolve_file "drift-fix settings" \
  "${FLINT_DRIFT_FIX_SETTINGS_FILE:-}" \
  "$HOME/.claude/flint-drift-fix-settings.json" \
  "$script_dir/../flint-drift-fix-settings.json")" || exit 1

prompt_body="$(cat "$prompt_file")"
exec claude \
  --append-system-prompt "$prompt_body" \
  --settings "$settings_file" \
  "$@"
