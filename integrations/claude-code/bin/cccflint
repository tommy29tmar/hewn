#!/usr/bin/env bash
# cccflint — Claude Code with Flint thinking-mode injected at system-prompt level.
#
# Wraps `claude` and appends the Flint thinking-mode system prompt via the
# --append-system-prompt flag. This is the ONLY mechanism in Claude Code that
# reaches system-prompt level — output-styles, hooks, skills, and CLAUDE.md all
# load as context and cannot override Claude Code's built-in system prompt.
#
# Prompt resolution order:
#   1. $FLINT_THINKING_PROMPT_FILE env var (explicit override)
#   2. $HOME/.claude/flint_thinking_system_prompt.txt (installer location)
#   3. $(dirname $0)/../flint_thinking_system_prompt.txt (repo checkout)
#
# Usage:
#   cccflint                              # interactive session with Flint thinking
#   cccflint -p "your prompt"             # non-interactive
#   cccflint --help                       # passes --help through to claude

set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

resolve_prompt_file() {
  if [ -n "${FLINT_THINKING_PROMPT_FILE:-}" ] && [ -f "$FLINT_THINKING_PROMPT_FILE" ]; then
    echo "$FLINT_THINKING_PROMPT_FILE"
    return
  fi
  local candidate="$HOME/.claude/flint_thinking_system_prompt.txt"
  if [ -f "$candidate" ]; then
    echo "$candidate"
    return
  fi
  candidate="$script_dir/../flint_thinking_system_prompt.txt"
  if [ -f "$candidate" ]; then
    echo "$candidate"
    return
  fi
  return 1
}

prompt_file="$(resolve_prompt_file)" || {
  echo "cccflint: flint_thinking_system_prompt.txt not found." >&2
  echo "Searched:" >&2
  echo "  \$FLINT_THINKING_PROMPT_FILE (unset or missing)" >&2
  echo "  $HOME/.claude/flint_thinking_system_prompt.txt" >&2
  echo "  $script_dir/../flint_thinking_system_prompt.txt" >&2
  exit 1
}

prompt_body="$(cat "$prompt_file")"
exec claude --append-system-prompt "$prompt_body" "$@"
